<class name="CCinemaSpotLightClip">
    <object name="CCinemaSpotLightClip">
      <field name="sName" type="String"/>
      <field name="disUniqueId" type="BinHex"/>
      <field name="bEnabled" type="Boolean"/>
      <field name="timeStartTime" type="Float"/>
      <field name="timeDuration" type="Float"/>
      <field name="timeEndTime" type="Float"/>
      <field name="hidResizable" type="BinHex"/>
      <field name="disMuted" type="BinHex"/>
      <field name="sAnimationTrackCollectionResource" type="BinHex"/>
      <field name="bResizable" type="Boolean"/>
      <field name="hidAnimationTrackCollectionDuration" type="BinHex"/>
      <object name="AnimationTrackCollection">
        <object name="Tracks">
          <object name="Track">
            <object name="Track">
              <field name="text_hid_DTCTH_ClassName" type="String"/>
              <field name="hid_DTCTH_ClassName" type="BinHex"/>
              <field name="Name" type="String"/>
              <field name="Master" type="BinHex"/>
              <field name="UseCustomAnimation" type="BinHex"/>
              <object name="Keys">
                <object name="Key">
                  <field name="TimePrecise" type="BinHex"/>
                  <field name="Value" type="BinHex"/>
                  <object name="TangentIn">
                    <field name="Time" type="BinHex"/>
                    <field name="Value" type="BinHex"/>
                  </object>
                  <object name="TangentOut">
                    <field name="Time" type="BinHex"/>
                    <field name="Value" type="BinHex"/>
                  </object>
                </object>
              </object>
            </object>
          </object>
        </object>
      </object>
      <object name="Light">
        <field name="bApplyRotation" type="Boolean"/>
        <field name="bSpecular" type="Boolean"/>
        <field name="bHalfLambert" type="Boolean"/>
        <field name="bHasElectricBackup" type="Boolean"/>
        <field name="text_sBoneId" type="String"/>
        <field name="sBoneId" type="BinHex"/>
        <field name="bAffectedByTimeOfDay" type="Boolean"/>
        <field name="vectorPositionOffset" type="Vector"/>
        <field name="bQuadraticAttenuation" type="Boolean"/>
        <field name="bNeedsElectricPower" type="Boolean"/>
        <field name="bAffectsGeometry" type="Boolean"/>
        <field name="bAffectsParticles" type="Boolean"/>
      </object>
      <object name="SpotLight">
        <field name="bCastShadow" type="Boolean"/>
        <field name="bHighQualityShadowFiltering" type="Boolean"/>
		<field name="text_fileTexture" type="String"/>
        <field name="fileTexture" type="BinHex"/>
        <field name="fSizeOnPlane" type="Float"/>
        <field name="fClipDistance" type="Float"/>
        <field name="fDoubleSpecularOffset" type="Float"/>
      </object>
    </object>
</class>