<?xml version="1.0" encoding="utf-8"?>
<class name="BloomParameters">
	<inherit name="SharedParameters"/>
	<field name="bEnabled" type="Boolean"/>
	<field name="bEnabledOverride" type="Boolean"/>
	<field name="bIntensityOverride" type="Boolean"/>
	<field name="bCenterBoostOverride" type="Boolean"/>
	<field name="bLuminanceThresholdOverride" type="Boolean"/>
	<field name="fChromaticAberrationOffset" type="Float"/>
	<field name="bChromaticAberrationOffsetOverride" type="Boolean"/>
	<field name="fArtifactUVScale" type="Float"/>
	<field name="bArtifactUVScaleOverride" type="Boolean"/>
	<field name="fArtifactCut" type="Float"/>
	<field name="bArtifactCutOverride" type="Boolean"/>
	<field name="fArtifactIntensity" type="Float"/>
	<field name="bArtifactIntensityOverride" type="Boolean"/>
	<object name="curveIntensity">
		<inherit name="KnotsParameters"/>
	</object>
	<object name="curveCenterBoost">
		<inherit name="KnotsParameters"/>
	</object>
	<object name="curveLuminanceThreshold">
		<inherit name="KnotsParameters"/>
	</object>
	<object name="AdvancedFiltering">
		<field name="bScreenCoverageOverride" type="Boolean"/>
		<field name="iDownsamplePower" type="Int32"/>
		<field name="bDownsamplePowerOverride" type="Boolean"/>
		<field name="iExtraBlurCount" type="Int32"/>
		<field name="bExtraBlurCountOverride" type="Boolean"/>
		<object name="curveScreenCoverage">
			<inherit name="KnotsParameters"/>
		</object>
	</object>
</class>