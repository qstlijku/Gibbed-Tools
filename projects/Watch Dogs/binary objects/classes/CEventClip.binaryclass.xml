<class name="CEventClip">
    <object name="CEventClip">
        <field name="sName" type="String"/>
        <field name="disUniqueId" type="BinHex"/>
        <field name="bEnabled" type="Boolean"/>
        <field name="timeStartTime" type="Float"/>
        <field name="timeDuration" type="Float"/>
        <field name="timeEndTime" type="Float"/>
        <field name="hidResizable" type="BinHex"/>
        <field name="disMuted" type="BinHex"/>
        <field name="text_hidTypeName" type="String"/>
        <field name="hidTypeName" type="BinHex"/>
        <field name="sEvent" type="String"/>
        <field name="bFireWhenInterrupted" type="Boolean"/>
        <object name="Event">
            <field name="text_hid_DTCTH_ClassName" type="String"/>
            <field name="hid_DTCTH_ClassName" type="BinHex"/>
            <field name="hidEventName" type="String"/>
            <field name="eventMask" type="BinHex"/>
            <field name="hidTargetEntityId" type="BinHex"/>
			<field name="RandomNumberSeed" type="BinHex"/>
			<field name="hidType" type="BinHex"/>
            <field name="bSkipMobsterNPC" type="Boolean"/>
            <field name="bSkipPoliceNPC" type="Boolean"/>
            <field name="bSkipMobsterVehicle" type="Boolean"/>
            <field name="bSkipPoliceVehicle" type="Boolean"/>
            <field name="bSkipPlayer" type="Boolean"/>
            <field name="bSkipCivilian" type="Boolean"/>
            <field name="bSkipTraffic" type="Boolean"/>
        </object>
    </object>
</class>